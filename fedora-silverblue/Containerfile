# Copy custom config to /usr & /etc
COPY usr usr
COPY etc etc

# COPY --from=rpms /tmp/rpms /tmp/rpms
COPY --from=builder /tmp/rpms /tmp/rpms

# COPY --from=builder /usr/src/nvidia* /usr/src/nvidia
# COPY --from=builder /var/lib/dkms/ /var/lib/dkms/
COPY --from=builder /opt/nvidia/modules-extra /usr/lib/modules/extra

# COPY --from=builder /var/roothome/.cargo/bin/bcvk /usr/bin/

COPY scripts /tmp/scripts

# RUN --mount=type=cache,target=/var/roothome/.cache \
#     --mount=type=cache,dst=/var/cache/dnf \
#     --mount=type=cache,dst=/var/cache/libdnf5 \
#     <<EORUN
RUN <<EORUN
    set -xeuo pipefail
    export FORCE_COLUMNS=134

    # https://www.mankier.com/1/gpg#Files-GNUPGHOME
    export GNUPGHOME="/tmp/.gnupg"

    dnf upgrade --enablerepo=updates-testing --assumeyes --refresh --no-allow-downgrade --allowerasing

    /tmp/scripts/initramfs.sh

    # /tmp/scripts/install-kmod-nvidia-open-dkms-toolkit.sh
    /tmp/scripts/nvidia/install-nvidia-negativo17.sh

    dnf swap --assumeyes --refresh --allowerasing nano vim-default-editor

    # /tmp/scripts/initramfs-zstd.sh
    # /tmp/scripts/fedora-packages.sh
    # /tmp/scripts/install-qemu.sh
    # /tmp/scripts/install-libvirtd.sh
    
    /tmp/scripts/install-vscodium.sh

    # /tmp/scripts/koji-download-build/run-koji-download-build.sh
    dnf install --assumeyes --refresh --no-allow-downgrade --allowerasing \
        /tmp/rpms/*.rpm
    # --setopt=install_weak_deps=False \
    # --exclude gcc \

    # dnf install --assumeyes --refresh --allowerasing \
    # --exclude=mercurial,subversion \
    # $(grep -Ev '^#|^$' /tmp/scripts/dnf-install-fedora-packages.txt)

    dnf upgrade --enablerepo=updates-testing --assumeyes --refresh --no-allow-downgrade --allowerasing

    rpm --erase --nodeps \
        $(grep --extended-regexp --invert-match '^#|/|^$' /tmp/scripts/rpm-erase-fedora-packages.txt)
    # dnf remove --assumeyes --refresh --no-autoremove \
        # $(grep --extended-regexp --invert-match '^#|^$' /tmp/scripts/dnf-remove-fedora-packages.txt)
    dnf remove --assumeyes --refresh \
        $(grep --extended-regexp --invert-match '^#|^$' /tmp/scripts/dnf-remove-fedora-packages.txt)
    # --setopt=excludepkgs=golang \
    # --exclude golang \

    groups=("usbmon" "wireshark")
    for group in ${groups[@]}; do
        groupdel ${group}
    done
EORUN

# Cleanup
RUN <<EORUN
    set -xeuo pipefail
    export FORCE_COLUMNS=134

    rm --recursive --force \
        /usr/etc/yum.repos.d/_copr:copr.fedorainfracloud.org:phracek:PyCharm.repo \
        /usr/etc/yum.repos.d/fedora-multimedia.repo \
        /usr/etc/yum.repos.d/rpmfusion-nonfree-nvidia-driver.repo \
        /usr/etc/yum.repos.d/rpmfusion-nonfree-steam.repo

    rm --recursive --force /var/lib/unbound/root.key
    chmod ug-s \
        /usr/bin/chage \
        /usr/bin/chfn \
        /usr/bin/chsh \
        /usr/bin/gpasswd \
        /usr/bin/newgrp \
        /usr/bin/passwd \
        /usr/bin/vmware-user-suid-wrapper

    rpm-ostree cleanup --repomd
    dnf clean all

    # + rm --recursive --force /var /run /tmp /boot
    # rm: cannot remove '/run/.containerenv': Device or resource busy
    # rm: cannot remove '/run/secrets': Device or resource busy
    # rm: cannot remove '/run/systemd/resolve/stub-resolv.conf': Device or resource busy

    du --human-readable --total --max-depth=1 /run | \
        sort --human-numeric-sort | \
        grep --extended-regexp --invert-match '^0'
    # ls -lah /run
    # ls -lah /run/secrets
    # ls -lah /run/systemd
    # cat /run/.containerenv
    # umount --all-targets --force --no-mtab --recursive --types tmpfs --verbose /run
    # umount --all-targets --force --no-mtab --recursive --verbose /run
    # rm --verbose --dir --recursive --force /run
    # rm --recursive --force /var/* /tmp/* /boot/*
    # rm --recursive --force /var /run /tmp /boot
    rm --recursive --force /var /tmp /boot
    # rm --recursive --force /var /boot /tmp/dracut /tmp/rpms /tmp/scripts
    # rm --recursive --force /var /tmp /boot /usr/src/nvidia-* ${local_repo}
    # mkdir /var /run /tmp /boot
    mkdir /var /tmp /boot
    # mkdir /var /boot
    ls -lathr /tmp
    bootc container lint --no-truncate
    # bootc container lint --no-truncate --fatal-warnings
EORUN

