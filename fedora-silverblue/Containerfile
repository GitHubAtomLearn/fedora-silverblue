## Download RPMs of the latest builds for the f44-updates-testing tag

# FROM quay.io/fedora/fedora-minimal:44 AS rpms

ARG BASE_REPOSITORY
ARG VERSION_ID

ARG CHUNKAH_REPOSITORY
ARG CHUNKAH_TAG
ARG CHUNKAH_TMP_DIR
ARG CHUNKAH_TMP_IMAGE
ARG CHUNKAH_CONFIG_STR

FROM ${BASE_REPOSITORY}:${VERSION_ID} AS builder

RUN <<EORUN
    set -xeuo pipefail
    export FORCE_COLUMNS=134
    # Install the required packages
    # sed --in-place "s/enabled=1/enabled=0/" "/etc/yum.repos.d/fedora-cisco-openh264.repo"

    dnf upgrade --enablerepo=updates-testing --assumeyes --refresh --no-allow-downgrade --allowerasing

    dnf --assumeyes --refresh install --allowerasing --no-allow-downgrade \
        --no-docs --disable-repo fedora-cisco-openh264 \
        --setopt=install_weak_deps=False \
        --exclude container-selinux \
        python3-devel krb5-devel gcc
        # rust cargo rust-openssl-devel

    # # Install the dependencies
    # uv sync --directory /koji-download-build \
    #     --no-install-local --no-install-project --no-install-workspace
    # # Download RPMs of the latest builds for the f44-updates-testing tag
    # /koji-download-build/koji-download-build.py
EORUN

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Compile Python files to bytecode after installation.
# https://docs.astral.sh/uv/reference/cli/#uv-sync--compile-bytecode
ENV UV_COMPILE_BYTECODE=1

# The method to use when installing packages from the global cache.
# https://docs.astral.sh/uv/reference/cli/#uv-sync--link-mode
ENV UV_LINK_MODE=copy

# Configure the Python directory so it is consistent.
# The directory to store the Python installation in.
# https://docs.astral.sh/uv/reference/cli/#uv-python-install--install-dir
# ENV UV_PYTHON_INSTALL_DIR=/opt/python
ENV UV_PYTHON_INSTALL_DIR=/var/opt/python

# Whether uv should prefer system or managed Python versions.
# Only use the managed Python version.
# https://docs.astral.sh/uv/reference/environment/#uv_python_preference
# ENV UV_PYTHON_PREFERENCE=only-managed

# Require use of uv-managed Python versions.
# https://docs.astral.sh/uv/reference/cli/#uv-python-install--managed-python
ENV UV_MANAGED_PYTHON=1

# Disable the development dependency group
# https://docs.astral.sh/uv/reference/cli/#uv-sync--no-dev
ENV UV_NO_DEV=1

# Assert that the uv.lock will remain unchanged.
# https://docs.astral.sh/uv/reference/cli/#uv-sync--locked
ENV UV_LOCKED=1

# Set the working directory
WORKDIR /opt/koji-download-build

# Install the dependencies using the lockfile and settings
# RUN --mount=type=cache,target=/root/.cache/uv \
RUN --mount=type=cache,target=/var/roothome/.cache/uv \
    --mount=type=bind,source=scripts/koji-download-build/uv.lock,target=uv.lock,ro,relabel=private \
    --mount=type=bind,source=scripts/koji-download-build/pyproject.toml,target=pyproject.toml,ro,relabel=private <<EORUN
    set -xeuo pipefail
    # pwd
    # ls -Zlathri
    uv sync --no-install-local --no-install-project --no-install-workspace
EORUN

# Add the rest of the source code and install it
# Installing separately from its dependencies allows optimal layer caching
COPY scripts/koji-download-build /opt/koji-download-build
RUN --mount=type=cache,target=/var/roothome/.cache/uv <<EORUN
    set -xeuo pipefail
    # pwd
    # ls -Zlathri
    uv sync --no-install-local --no-install-project --no-install-workspace
EORUN

# Place executables in the environment at the front of the PATH environment variable
ENV PATH="/opt/koji-download-build/.venv/bin:${PATH}"

# Download RPMs of the latest builds for the f44-updates-testing tag
RUN <<EORUN
    set -xeuo pipefail
    /opt/koji-download-build/koji-download-build.py
    # ls -Zlathri /tmp/rpms
EORUN

# # Install bcvk
# RUN --mount=type=cache,target=/var/roothome/.cache <<EORUN
#     set -xeuo pipefail
#     cargo install --locked --git https://github.com/bootc-dev/bcvk bcvk
# EORUN

# COPY scripts/build-kmod-nvidia-open-dkms.sh /opt/build-kmod-nvidia-open-dkms/
# RUN <<EORUN
#     set -xeuo pipefail
#     /opt/build-kmod-nvidia-open-dkms/build-kmod-nvidia-open-dkms.sh
# EORUN

COPY scripts/nvidia/build-nvidia-negativo17.sh /opt/nvidia/
RUN --mount=type=cache,target=/var/roothome/.cache \
    --mount=type=cache,dst=/var/cache/dnf \
    --mount=type=cache,dst=/var/cache/libdnf5 \
    <<EORUN
    set -xeuo pipefail
    export FORCE_COLUMNS=134
    /opt/nvidia/build-nvidia-negativo17.sh
    dnf clean all
EORUN

